# ============================================
# NexBank Frontend — Environment Variables
# ============================================

# API base URL — used in production builds
# In development, Vite proxies /api → localhost:5000 (no CORS needed)
# Set this to your deployed backend URL for production builds:
VITE_API_URL=https://your-backend.onrender.com/api

# Vite proxy target (dev only) — defaults to http://localhost:5000
# VITE_API_TARGET=http://localhost:5000
